P25_REFLECTOR_NAME=AWP25
P25_TALKGROUP=10225
P25_NAC=927

# Directory and filename pattern for the P25Reflector application logs.
P25_LOG_DIR=/var/log/p25reflector
P25_LOG_PATTERN=P25Reflector*.log
P25_LOG_HISTORY=3

# JSON snapshot served by Apache. StateDirectory creates this parent directory.
P25_STATUS_FILE=/var/lib/awp25-monitor/status.json

# Optional callsign-to-site/operator labels.
# P25_NODES_FILE=/etc/awp25-nodes.json

# Collector timing in seconds. Browsers fetch the snapshot every second.
P25_POLL_INTERVAL=0.2
P25_PUBLISH_INTERVAL=1.0
P25_ONLINE_TIMEOUT=300
# P25Reflector sends node heartbeats about every 5 seconds. Four missed
# intervals removes the node from the connected list.
P25_NODE_TIMEOUT=20
